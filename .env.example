# EN: Copy this file to .env for local development.
# CN: 本地开发时复制为 .env。
# EN: Never commit real secrets or credentials.
# CN: 不要提交真实密钥或凭据。

APP_ENV=local
BACKEND_PORT=8080
FRONTEND_PORT=5173

# EN: Use the local mock agent during early development.
# CN: 早期开发使用本地 mock agent。
AGENT_PROVIDER=mock
AGENT_TIMEOUT_SECONDS=30

# EN: Keep empty until an integration explicitly needs it.
# CN: 仅在明确集成需要时填写。
LLM_API_KEY=
GITHUB_TOKEN=
